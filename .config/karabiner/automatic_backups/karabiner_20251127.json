{
    "description": "Disable Ctrl-J in Warp Terminal",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^dev\\.warp\\.Warp-Stable$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "from": {
                "key_code": "j",
                "modifiers": { "mandatory": ["control"] }
            },
            "to": [{ "key_code": "vk_none" }],
            "type": "basic"
        }
    ],
    "profiles": [
        {
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}